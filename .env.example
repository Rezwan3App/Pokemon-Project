# Server
PORT=3001
NODE_ENV=development

# Database: sqlite (default) | postgres
DATABASE_DRIVER=sqlite
DATABASE_PATH=./data/tracker.db

# Pokémon TCG API — card images/metadata — https://dev.pokemontcg.io/
POKEMON_TCG_API_KEY=

# Pricing mode:
#   mock = sample data only (no API key needed)
#   auto = try external pricing APIs below, then Pokémon TCG embed, then mock
PRICING_MODE=auto

# ── Recommended: PokéWallet (best for this app) ─────────────────────────────
# Sign up: https://pokewallet.io
# Free tier: 100 requests/hour · TCGPlayer + CardMarket · sealed products
POKEWALLET_API_KEY=

# ── Alternative: TCG API ────────────────────────────────────────────────────
# Sign up: https://tcgapi.dev/dashboard
# Free tier: 100 requests/day · daily TCGPlayer refresh · sealed products
TCGAPI_KEY=

# ── Official APIs (closed to new apps — stubs only) ─────────────────────────
TCGPLAYER_PUBLIC_KEY=
TCGPLAYER_PRIVATE_KEY=
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=

MOCK_PRICE_SEED=pokemon-tracker-mvp
PRICE_UPDATE_CRON=0 2 * * *
ENABLE_CRON=true
