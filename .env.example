# Server
PORT=3001
NODE_ENV=development

# Pokémon TCG API — optional but recommended (https://dev.pokemontcg.io/)
POKEMON_TCG_API_KEY=

# SQLite database path (relative to server/)
DATABASE_PATH=./data/tracker.db

# Mock market data seed (change for different deterministic prices)
MOCK_PRICE_SEED=pokemon-tracker-mvp
