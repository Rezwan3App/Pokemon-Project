# Server
PORT=3001
NODE_ENV=development

# Database: sqlite (default) | postgres
DATABASE_DRIVER=sqlite
DATABASE_PATH=./data/tracker.db
# For PostgreSQL (optional):
# DATABASE_URL=postgresql://user:password@localhost:5432/pokemon_tracker

# Pokémon TCG API — https://dev.pokemontcg.io/
POKEMON_TCG_API_KEY=

# MVP pricing: mock (default). Later: auto | tcgplayer | ebay
PRICING_MODE=mock

# Live pricing (optional — add keys after API approval)
TCGPLAYER_PUBLIC_KEY=
TCGPLAYER_PRIVATE_KEY=
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=

# Mock pricing seed (deterministic demo prices)
MOCK_PRICE_SEED=pokemon-tracker-mvp

# Daily price update schedule (cron expression, default 2:00 AM)
PRICE_UPDATE_CRON=0 2 * * *
# Set to false to disable automatic daily updates
ENABLE_CRON=true
